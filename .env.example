# Copie para .env e preencha com as suas chaves. NÃO comite o .env real.
#
# Estas 3 variáveis são PÚBLICAS (chegam ao navegador) — todas prefixadas VITE_.
# Nenhuma delas cobra ou movimenta dinheiro; o access token (secreto) do Mercado
# Pago vive apenas no Supabase, nunca aqui.

# URL do projeto Supabase, ex.: https://xxxxxxxx.supabase.co
VITE_SUPABASE_URL=

# Chave anônima (anon/public) do Supabase — segura para o frontend.
VITE_SUPABASE_ANON_KEY=

# Public key do Mercado Pago (começa com APP_USR- ou TEST- em sandbox).
VITE_MP_PUBLIC_KEY=
